{
    "name": "goaop/framework",
    "description": "Framework for aspect-oriented programming in PHP.",

    "type": "library",
    "keywords": ["library", "aop", "php", "aspect"],
    "homepage": "http://go.aopphp.com/",
    "license": "MIT",

    "require": {
        "php": "^8.4.0",
        "ext-tokenizer": "*",
        "goaop/parser-reflection": "4.x-dev",
        "goaop/dissect": "^4.0",
        "nikic/php-parser": "^5.0",
        "symfony/finder": "^7.4 || ^8.0"
    },

    "require-dev": {
        "adlawson/vfs": "^0.12.1",
        "doctrine/orm": "^2.5 || ^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "symfony/console": "^7.4 || ^8.0",
        "symfony/filesystem": "^7.4 || ^8.0",
        "symfony/process": "^7.4 || ^8.0",
        "tracy/tracy": "^2.10",
        "webmozart/glob": "^4.1"
    },

    "suggest": {
        "symfony/console": "Enables the usage of the command-line tool."
    },

    "bin": ["bin/aspect"],
    "authors": [
        {
            "name": "Lisachenko Alexander",
            "homepage": "https://github.com/lisachenko"
        }
    ],

    "autoload": {
        "psr-4": {
            "Go\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-0": {
            "Demo\\": "demos/"
        },
        "psr-4": {
            "Go\\": "tests/",
            "Go\\Tests\\TestProject\\": "tests/Fixtures/project/src/"
        },
        "files": [
            "tests/functions.php",
            "tests/Stubs/ClassWithoutNamespace.php",
            "tests/Proxy/Generator/Stubs/AttributeGroupsGeneratorStubs.php",
            "tests/Proxy/Generator/Stubs/FunctionGeneratorStubs.php",
            "tests/Proxy/Generator/Stubs/TypeGeneratorStubs.php",
            "tests/Proxy/Generator/Stubs/ParameterGeneratorStubs.php"
        ]
    },

    "minimum-stability": "stable",
    "extra": {
        "branch-alias": {
            "dev-master": "4.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
